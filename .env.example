# ─────────────────────────────────────────────
#  Vision Guard – Environment Variables
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server
PORT=5000
NODE_ENV=development

# CORS – set to your frontend origin in production
CORS_ORIGIN=http://localhost:5173

# AI Endpoint (Cloudflare Tunnel URL)
# This is a fallback. The live URL is stored in the
# system_info table and can be updated via PUT /api/ai/config
# without restarting the server.
AI_ENDPOINT_URL=https://your-tunnel.trycloudflare.com

# How often (seconds) the poller fetches from the AI
# Can also be changed via the settings API at runtime
AI_POLL_INTERVAL_SEC=30
